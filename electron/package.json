{
  "name": "photonic-designer",
  "version": "1.0.0",
  "description": "Photonic IC Layout Designer \u2014 IHP SiN PDK",
  "main": "main.js",
  "author": "Photonic Designer Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:win-x64": "electron-builder --win --x64",
    "build:win-arm64": "electron-builder --win --arm64",
    "build:mac-x64": "electron-builder --mac --x64",
    "build:mac-arm64": "electron-builder --mac --arm64",
    "build:all": "electron-builder --win --mac --x64 --arm64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "googleapis": "^130.0.0",
    "node-machine-id": "^1.1.12",
    "systeminformation": "^5.21.0",
    "crypto-js": "^4.2.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.3.9",
    "portfinder": "^1.0.32"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.photonicdesigner.app",
    "productName": "Photonic Designer",
    "copyright": "Copyright \u00a9 2026 Photonic Designer",
    "directories": {
      "output": "../build",
      "buildResources": "resources"
    },
    "files": [
      "**/*",
      "!**/*.map",
      "!**/node_modules/.cache/**"
    ],
    "extraResources": [
      {
        "from": "../src",
        "to": "app-src",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../pdk",
        "to": "pdk",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../config",
        "to": "config",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../python-embed",
        "to": "python-embed",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "resources/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "${productName}-Setup-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "resources/license.txt"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png",
      "category": "Development"
    },
    "publish": null
  }
}